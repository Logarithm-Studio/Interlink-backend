# ─── Server ────────────────────────────────────────────────────────────────────
PORT=5000

# ─── PostgreSQL (Supabase) ─────────────────────────────────────────────────────
# URL-encode special characters in the password (e.g. @ → %40)
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# ─── Supabase Auth ─────────────────────────────────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<supabase-service-role-key>
# Backward-compatibility alias (optional)
# SUPABASE_KEY=<supabase-service-role-key>
# Optional: comma-separated additional accepted JWT issuers
# (e.g. when migrating between Supabase projects).
# Values should look like: https://<project-ref>.supabase.co/auth/v1
# SUPABASE_ALLOWED_ISSUERS=
# Optional: comma-separated accepted JWT audiences (default: authenticated)
# SUPABASE_JWT_AUDIENCES=authenticated
# Optional clock skew tolerance in seconds (default: 30)
# SUPABASE_JWT_CLOCK_TOLERANCE_SECONDS=30

# ─── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=<google-client-id>
GOOGLE_CLIENT_SECRET=<google-client-secret>
GOOGLE_API_KEY=<google-maps-api-key>

GOOGLE_REDIRECT_URI=http://localhost:5000/api/v1/auth/callback/google

# Optional app deep-link redirects after Google callback (recommended for mobile)
# Example Android deep links: interlink://oauth/google/success, interlink://oauth/google/error
GOOGLE_OAUTH_SUCCESS_REDIRECT_URI=
GOOGLE_OAUTH_ERROR_REDIRECT_URI=
# Publicly reachable HTTPS URL Google will POST webhook notifications to.
# In dev use an ngrok/localtunnel URL; in production use your deployed API URL.
GOOGLE_WEBHOOK_URL=https://<your-public-domain>/api/v1/calendar/webhook/google

# ─── Email Verification (4-digit OTP via SMTP) ───────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=<smtp-username>
SMTP_PASS=<smtp-password-or-app-password>
SMTP_SECURE=false
SMTP_FROM=Interlink <no-reply@interlink.com>
# Optional. If omitted, ACTION_SIGNING_SECRET is used.
EMAIL_VERIFICATION_TOKEN_SECRET=<strong-random-secret>
# Optional hardening pepper for OTP hashing.
EMAIL_VERIFICATION_PEPPER=<strong-random-secret>
# Optional override (minutes)
# EMAIL_VERIFICATION_CODE_TTL_MINUTES=10

MICROSOFT_CLIENT_SECRET=<microsoft-client-secret>

# ─── QStash (Upstash background jobs) ─────────────────────────────────────────
# Required by server.ts and jobQueue.service.ts.
# Get all three from: https://console.upstash.com -> QStash -> pick a region ->
# "Request Builder" tab -> QSTASH_TOKEN / SIGNING KEYS pills.
API_BASE_URL=http://localhost:5000
QSTASH_TOKEN=<qstash-token>
QSTASH_CURRENT_SIGNING_KEY=<qstash-current-signing-key>
QSTASH_NEXT_SIGNING_KEY=<qstash-next-signing-key>

# ─── Token Encryption ─────────────────────────────────────────────────────────
# 32-byte hex key used for AES-256-GCM encryption of provider tokens at rest.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=<64-hex-chars>
# Optional rotation key (add ENCRYPTION_KEY_2, ENCRYPTION_KEY_3, ... for rotation)

# ─── Signed Action Tokens (Workflow resume deep links) ─────────────────────────
# 32-byte hex key used to HMAC-sign workflow action tokens.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ACTION_SIGNING_SECRET=<64-hex-chars>

# ─── AI Provider — Personal Mode ─────────────────────────────────────────────
# Supports: openai, gemini, demo. Gemini is now the recommended personal mode provider.
AI_PROVIDER=gemini
GEMINI_API_KEY=<gemini-api-key>
GEMINI_MODEL=gemini-2.5-flash
# Legacy OpenAI (set AI_PROVIDER=openai to use instead):
AI_API_KEY=<openai-api-key>
AI_MODEL=gpt-4o
AI_RATE_LIMIT_PER_USER_PER_HOUR=20

# ─── AI Provider — Professional Mode (Gemini) ────────────────────────────────
# Used by Professional Mode flows. Set PROFESSIONAL_AI_PROVIDER=demo to run offline.
PROFESSIONAL_AI_PROVIDER=gemini
# GEMINI_API_KEY and GEMINI_MODEL are shared with Personal Mode above.

# ─── Firebase / FCM (push notifications) ─────────────────────────────────────
# Required for push notification delivery via FCM v1 API.
# If not set, push delivery is skipped and email fallback is used instead.
#
# FIREBASE_PROJECT_ID    — GCP project ID (e.g. "my-project-12345")
# FIREBASE_SERVICE_ACCOUNT_KEY — full JSON of a Firebase service-account key,
#   exported from Firebase Console → Project Settings → Service accounts,
#   encoded as a single-line JSON string.
#   Example (do not commit real keys):
#   FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
FIREBASE_PROJECT_ID=<firebase-project-id>
FIREBASE_SERVICE_ACCOUNT_KEY=<json-string-of-service-account-key>

# ─── Third-party Integrations — Personal Mode ─────────────────────────────────
# Mobile OAuth: the redirect URI is the APP's custom scheme
# (interlinkapp://oauth/<provider>). Register the SAME URI in each provider's
# developer console. Set *_REDIRECT_URI only to override the default.
# Spotify (free developer API). Register interlinkapp://oauth/spotify.
# Get both from: https://developer.spotify.com/dashboard -> your app -> Settings
# (Client Secret is hidden behind a "View client secret" button).
SPOTIFY_CLIENT_ID=<spotify-client-id>
SPOTIFY_CLIENT_SECRET=<spotify-client-secret>
# SPOTIFY_REDIRECT_URI=interlinkapp://oauth/spotify

# OpenWeatherMap (free tier — 1M calls/month, no user OAuth needed)
# Get it from: https://openweathermap.org/api -> sign up -> "API keys" tab.
# New keys can take up to ~2 hours to activate.
OPENWEATHERMAP_API_KEY=<openweathermap-api-key>

# Todoist (free developer API). Register interlinkapp://oauth/todoist.
# Get both from: https://developer.todoist.com/appconsole.html -> create an app.
TODOIST_CLIENT_ID=<todoist-client-id>
TODOIST_CLIENT_SECRET=<todoist-client-secret>
# TODOIST_REDIRECT_URI=interlinkapp://oauth/todoist

# Notion (free developer API). Register interlinkapp://oauth/notion.
# Get both from: https://www.notion.so/my-integrations -> New integration ->
# choose "Public integration"/OAuth -> "OAuth Domain & URIs" tab.
NOTION_CLIENT_ID=<notion-client-id>
NOTION_CLIENT_SECRET=<notion-client-secret>
# NOTION_REDIRECT_URI=interlinkapp://oauth/notion

# Google Tasks + Google Fit: no new OAuth needed — add scopes below to Google OAuth flow:
# https://www.googleapis.com/auth/tasks
# https://www.googleapis.com/auth/fitness.activity.read
# https://www.googleapis.com/auth/spreadsheets

# ─── Third-party Integrations — Professional Mode ──────────────────────────────
# Trello (API key + secret from a Power-Up in the Power-Up Admin Portal — free).
# Get both from: https://trello.com/power-ups/admin -> your Power-Up -> "API key" tab.
# Only TRELLO_API_KEY is read by the backend today; TRELLO_SECRET is stored for
# future use (e.g. webhook signature verification) but not currently required.
TRELLO_API_KEY=<trello-api-key>
TRELLO_SECRET=<trello-api-secret>
TRELLO_REDIRECT_URI=interlinkapp://oauth/trello

# GitHub (free). Register interlinkapp://oauth/github as the callback URL.
# Get both from: https://github.com/settings/developers -> OAuth Apps -> New OAuth App.
GITHUB_CLIENT_ID=<github-client-id>
GITHUB_CLIENT_SECRET=<github-client-secret>
# GITHUB_REDIRECT_URI=interlinkapp://oauth/github

# Jira / Atlassian (free — OAuth 2.0 3LO app). Wired: src/services/jira/jira.service.ts,
# routes at /api/v1/jira. Get both from: https://developer.atlassian.com/console/myapps
# -> your app -> Settings (Client ID + Secret). Under Permissions add the "Jira API"
# with classic scopes: read:jira-work, write:jira-work, read:jira-user
# (manage:jira-webhook optional, only if using webhook sync). offline_access is NOT a
# console scope — the backend appends it to the authorization URL to get refresh tokens.
# Callback URL registered in the console: interlinkapp://oauth/jira
# Jira quirk (handled in code): after OAuth the service calls
# https://api.atlassian.com/oauth/token/accessible-resources to resolve the cloudId,
# then calls https://api.atlassian.com/ex/jira/{cloudId}/rest/api/3/...
JIRA_CLIENT_ID=<jira-client-id>
JIRA_CLIENT_SECRET=<jira-client-secret>
JIRA_REDIRECT_URI=interlinkapp://oauth/jira

# Slack (free — OAuth v2 bot token). Wired: src/services/slack/slack.service.ts,
# routes at /api/v1/slack. Get all three from https://api.slack.com/apps -> your app
# -> Basic Information -> App Credentials. Add Bot Token Scopes chat:write,
# channels:read, channels:history, users:read under OAuth & Permissions.
# NOTE: Slack blocks custom URI schemes without PKCE, so this uses an HTTPS backend
# callback instead. Register SLACK_REDIRECT_URI as a Redirect URL in the Slack app;
# the backend exchanges the code then deep-links to the app (SLACK_APP_REDIRECT).
# SLACK_SIGNING_SECRET is used to verify inbound Slack event webhooks.
SLACK_CLIENT_ID=<slack-client-id>
SLACK_CLIENT_SECRET=<slack-client-secret>
SLACK_SIGNING_SECRET=<slack-signing-secret>
SLACK_REDIRECT_URI=https://<your-api-domain>/api/v1/slack/callback
# Optional: deep link the browser is sent to after the callback completes
# SLACK_APP_REDIRECT=interlinkapp://oauth/slack

# ─── App base URL (used in notification email fallback deep links) ─────────────
APP_BASE_URL=https://app.interlink.com

# ─── Optional overrides ────────────────────────────────────────────────────────
# Override the dotenv file path (useful for Docker / CI)
# DOTENV_PATH=.env
# Minimum log level: trace | debug | info | warn | error | fatal (default: info)
# LOG_LEVEL=info
# Comma-separated IPs/prefixes that bypass the webhook rate limiter (Google IPs)
# RATE_LIMIT_WEBHOOK_ALLOWLIST_IPS=66.249.,34.64.,209.85.
