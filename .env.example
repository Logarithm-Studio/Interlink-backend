# ─── Server ────────────────────────────────────────────────────────────────────
PORT=5000

# ─── PostgreSQL (Supabase) ─────────────────────────────────────────────────────
# URL-encode special characters in the password (e.g. @ → %40)
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# ─── Supabase Auth ─────────────────────────────────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_KEY=<anon-public-key>
# Optional: comma-separated additional accepted JWT issuers
# (e.g. when migrating between Supabase projects).
# Values should look like: https://<project-ref>.supabase.co/auth/v1
# SUPABASE_ALLOWED_ISSUERS=
# Optional: comma-separated accepted JWT audiences (default: authenticated)
# SUPABASE_JWT_AUDIENCES=authenticated
# Optional clock skew tolerance in seconds (default: 30)
# SUPABASE_JWT_CLOCK_TOLERANCE_SECONDS=30

# ─── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=<google-client-id>
GOOGLE_CLIENT_SECRET=<google-client-secret>
GOOGLE_REDIRECT_URI=http://localhost:5000/api/v1/auth/callback/google
# Optional app deep-link redirects after Google callback (recommended for mobile)
# Example Android deep links: interlink://oauth/google/success, interlink://oauth/google/error
GOOGLE_OAUTH_SUCCESS_REDIRECT_URI=
GOOGLE_OAUTH_ERROR_REDIRECT_URI=
# Publicly reachable HTTPS URL Google will POST webhook notifications to.
# In dev use an ngrok/localtunnel URL; in production use your deployed API URL.
GOOGLE_WEBHOOK_URL=https://<your-public-domain>/api/v1/calendar/webhook/google

MICROSOFT_CLIENT_SECRET=<microsoft-client-secret>

# ─── Redis (Upstash) ───────────────────────────────────────────────────────────
# Use rediss:// (TLS) for Upstash
REDIS_URL=rediss://default:<token>@<host>.upstash.io:6379

# ─── Token Encryption ─────────────────────────────────────────────────────────
# 32-byte hex key used for AES-256-GCM encryption of provider tokens at rest.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=<64-hex-chars>
# Optional rotation key (add ENCRYPTION_KEY_2, ENCRYPTION_KEY_3, ... for rotation)

# ─── Signed Action Tokens (Workflow resume deep links) ─────────────────────────
# 32-byte hex key used to HMAC-sign workflow action tokens.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ACTION_SIGNING_SECRET=<64-hex-chars>

# ─── AI Provider ──────────────────────────────────────────────────────────────
# Used by src/services/ai/provider.ts (filled in at Step 15)
AI_PROVIDER=openai
AI_API_KEY=<ai-provider-api-key>
AI_MODEL=gpt-4o
AI_RATE_LIMIT_PER_USER_PER_HOUR=20

# ─── Firebase / FCM (push notifications) ─────────────────────────────────────
# Required for push notification delivery via FCM v1 API.
# If not set, push delivery is skipped and email fallback is used instead.
#
# FIREBASE_PROJECT_ID    — GCP project ID (e.g. "my-project-12345")
# FIREBASE_SERVICE_ACCOUNT_KEY — full JSON of a Firebase service-account key,
#   exported from Firebase Console → Project Settings → Service accounts,
#   encoded as a single-line JSON string.
#   Example (do not commit real keys):
#   FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
FIREBASE_PROJECT_ID=<firebase-project-id>
FIREBASE_SERVICE_ACCOUNT_KEY=<json-string-of-service-account-key>

# ─── App base URL (used in notification email fallback deep links) ─────────────
APP_BASE_URL=https://app.interlink.com

# ─── Optional overrides ────────────────────────────────────────────────────────
# Override the dotenv file path (useful for Docker / CI)
# DOTENV_PATH=.env
# Minimum log level: trace | debug | info | warn | error | fatal (default: info)
# LOG_LEVEL=info
# Comma-separated IPs/prefixes that bypass the webhook rate limiter (Google IPs)
# RATE_LIMIT_WEBHOOK_ALLOWLIST_IPS=66.249.,34.64.,209.85.

# 
docker run --name interlink-redis -p 6379:6379 redis:7-alpine
