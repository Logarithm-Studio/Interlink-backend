    {
      "name": "Supabase Auth",
      "item": [
        {
          "name": "Supabase Sign Up (Create User)",
          "id": "c7b2882c-19c8-431e-93ea-867404456527",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "apikey",
                "value": "{{supabaseAnonKey}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{testEmail}}\",\n  \"password\": \"{{testPassword}}\"\n}"
            },
            "url": {
              "raw": "{{supabaseUrl}}/auth/v1/signup",
              "host": ["{{supabaseUrl}}"],
              "path": ["auth", "v1", "signup"]
            }
          },
          "response": []
        },
        {
          "name": "Supabase Sign In (Password Grant + Save JWT)",
          "event": [
            {
              "listen": "test",
              "script": {
                "id": "92f78811-141c-4c1c-af92-7f1b3cc7d9ad",
                "exec": [
                  "let body = {};",
                  "try { body = pm.response.json(); } catch (e) {}",
                  "if (body.access_token) {",
                  "  pm.collectionVariables.set('jwt', body.access_token);",
                  "  pm.globals.set('jwt', body.access_token);",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "id": "c4915fc8-66e7-4575-906c-44dbf3dcd1b9",
                "exec": [""],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "id": "0d9efcfe-773f-4c97-b856-a6b865c76689",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "apikey",
                "value": "{{supabaseAnonKey}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{testEmail}}\",\n  \"password\": \"{{testPassword}}\"\n}"
            },
            "url": {
              "raw": "{{supabaseUrl}}/auth/v1/token?grant_type=password",
              "host": ["{{supabaseUrl}}"],
              "path": ["auth", "v1", "token"],
              "query": [
                {
                  "key": "grant_type",
                  "value": "password",
                  "uuid": "5e8492c7-4532-485c-a9e4-44ab1096912f"
                }
              ]
            }
          },
